#include<iostream>
#include<vector>
#include<cmath>
using namespace std;
bool isPrime(int n)
{
    if(n==0 || n==1) return false;
    if(n==2) return true;
    if(n!=2 && n%2==0) return false;
    for(int i=3;i*i<=n;i+=2)
    {
        if(n%i==0)
        {
            return false;
        }
    }
    return true;
}
int sumOfPrimes(int a,int b)
{
    int sum=0;
    for(int i=a;i<=b;i++)
    {
        if(isPrime(i))
        {
            sum+=i;
        }
    }
    return sum;
}
int main()
{
    int x,y;
    cin>>x>>y;
    cout<<sumOfPrimes(x,y);
}

