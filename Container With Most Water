#include<iostream>
#include<vector>
using namespace std;
int areaOfContainerWithMostWater(vector<int>& v,int n)
{
    int first=0,last=n-1;
    int max_area=0;
    while(first<last)
    {
        int width=last-first;
        int height=min(v[first],v[last]);
        int area=width*height;
        if(area>max_area)
        {
            max_area=area;
        }
        if(v[first]<v[last])
        {
            first++;
        }
        else
        {
            last--;
        }
    }
    return max_area;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    int ans=areaOfContainerWithMostWater(v,n);
    cout<<ans;
}

