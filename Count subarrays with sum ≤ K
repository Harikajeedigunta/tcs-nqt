#include<iostream>
#include<vector>
using namespace std;
int countOfSubArrays(vector<int>& v,int n,int k)
{
    if(n<=0) return 0;
    int sum=0;
    int count=0;
    int i=0;
    for(int j=0;j<n;j++)
    {
        sum+=v[j];
        while(sum>k)
        {
            sum-=v[i];
            i++;
        }
        count+=j-i+1;
    }
    return count;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<countOfSubArrays(v,n,k);
}

