#include<iostream>
#include<vector>
#include<unordered_map>
using namespace std;
void firstRepeatingElement(vector<int>& v,int n)
{
    unordered_map<int,int>mp;
    for(auto x:v)
    {
        mp[x]+=1;
    }
    for(auto x:v)
    {
        if(mp[x]>1)
        {
            cout<<x<<endl;
            return;
        }
    }
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    firstRepeatingElement(v,n);
}

