#include<iostream>
#include<unordered_map>
#include<vector>
using namespace std;
void countOfUniqueNumsInEveryWindow(vector<int>& v,int n,int k)
{
    int count=0;
    unordered_map<int,int>mp;
    for(int i=0;i<k;i++)
    {
        mp[v[i]]+=1;
    }
    cout<<mp.size()<<" ";
    for(int i=k;i<n;i++)
    {
        mp[v[i-k]]--;
        if(mp[v[i-k]]==0)
        {
            mp.erase(v[i-k]);
        }
        mp[v[i]]++;
        cout<<mp.size()<<" ";
    }
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    countOfUniqueNumsInEveryWindow(v,n,k);
}

