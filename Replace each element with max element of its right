#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;
void replaceElement(vector<int>&nums,int n)
{
    int max_right=-1;
    for(int i=n-1;i>=0;i--)
    {
        int temp=nums[i];
        nums[i]=max_right;
        max_right=max(max_right,temp);
    }
    for(auto x:nums)
    {
        cout<<x<<" ";
    }
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    replaceElement(v,n);
}

