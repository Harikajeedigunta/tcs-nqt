#include<iostream>
#include<vector>
using namespace std;
int countOccurencesOfK(vector<int>& nums,int n,int k)
{
    int low=0,high=n-1;
    int result=-1;
    while(low<=high)
    {
        int mid=low+(high-low)/2;
        if(nums[mid]==k)
        {
            result=mid;
            high=mid-1;
        }
        else if(nums[mid]<k)
        {
            low=mid+1;
        }
        else
        {
            high=mid-1;
        }
    }
    return result;
}
