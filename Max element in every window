#include<iostream>
#include<deque>
#include<climits>
#include<vector>
using namespace std;
void maxEleInEveryWindow(vector<int>& v,int n,int k)
{
    deque<int>dq;
    for(int i=0;i<n;i++)
    {
        if(!dq.empty() && dq.front()<=i-k)
        {
            dq.pop_front();
        }
        while(!dq.empty() && v[dq.back()]<v[i])
        {
            dq.pop_back();
        }
        dq.push_back(i);
        if(i>=k-1)
        {
            cout<<v[dq.front()]<<" ";
        }
    }
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    maxEleInEveryWindow(v,n,k);
}

