#include<iostream>
#include<vector>
#include<unordered_map>
#include<climits>
using namespace std;
int mostFrequentElement(vector<int>& v,int n)
{
    unordered_map<int,int>mp;
    int max_frequency=0;
    int max_frequent_ele=INT_MIN;
    for(int x:v)
    {
        mp[x]+=1;
    }
    for(const pair<int,int>& p:mp)
    {
        if(p.second>max_frequency)
        {
            max_frequency=p.second;
            max_frequent_ele=p.first;
        }
    }
    return max_frequent_ele;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<mostFrequentElement(v,n);
}

