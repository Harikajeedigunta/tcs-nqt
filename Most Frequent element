If there multiple elements with same frequency then we have to return smallest among them
#include<iostream>
#include<vector>
#include<climits>
#include<unordered_map>
using namespace std;
int max_fre_ele(vector<int>& v,int n)
{
    int max_fre=0;
    int min_ele=INT_MAX;
    unordered_map<int,int>mp;
    for(int x:v)
    {
        mp[x]+=1;
    }
    for(const pair<int,int>& p:mp)
    {
        if(p.second>max_fre)
        {
            max_fre=p.second;
            min_ele=p.first;
        }
        else if(max_fre==p.second && p.first<min_ele)
        {
            min_ele=p.first;
        }
    }
    return min_ele;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<max_fre_ele(v,n);
}
Input:
6
1 1 2 2 3 3

Output:
1
