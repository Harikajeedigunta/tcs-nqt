#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;
void leftRotateArray(vector<int>& v,int n,int k)
{
    if(n==0) return;
    k=k%n;
    reverse(v.begin(),v.begin()+k);
    reverse(v.begin()+k,v.end());
    reverse(v.begin(),v.end());
    for(int i=0;i<n;i++)
    {
        cout<<v[i]<<" ";
    }
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    leftRotateArray(v,n,k);
}

