#include<iostream>
#include<algorithm>
#include<climits>
#include<vector>
using namespace std;
pair<int,int> closestPairToTarget(vector<int>& v,int n,int k)
{
    if(n<2) return {-1,-1};
    sort(v.begin(),v.end());
    pair<int,int>ans;
    int first=0,last=n-1;
    int min_diff=INT_MAX;
    while(first<last)
    {
        int sum=v[first]+v[last];
        int diff=abs(sum-k);
        if(diff<min_diff)
        {
            min_diff=diff;
            ans={v[first],v[last]};
        }
        if(sum<k) first++;
        else last--;
    }
    return ans;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    pair<int,int>result=closestPairToTarget(v,n,k);
    cout<<result.first<<" "<<result.second<<endl;
}

