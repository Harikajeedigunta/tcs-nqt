#include<iostream>
#include<vector>
#include<climits>
using namespace std;
int findMin(vector<int>& nums)
{
    int n=nums.size();
    int low=0,high=n-1,min_ele=INT_MAX;
    while(low<=high)
    {
        int mid=(low+high)/2;
        if(nums[low] <= nums[high])
        {
            min_ele = min(min_ele, nums[low]);
            break;
        }
        if(nums[low]<=nums[mid])
        {
            min_ele=min(min_ele,nums[low]);
            low=mid+1;
        }
        else
        {
            min_ele=min(min_ele,nums[mid]);
            high=mid-1;
        }
    }
    return min_ele;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<findMin(v);
}

