#include<iostream>
#include<vector>
using namespace std;
bool sortedAndRotated(vector<int>& nums,int n)
{
    int count=0;
    for(int i=0;i<n;i++)
    {
        if(nums[i]>nums[(i+1)%n])
        {
            count+=1;
        }
    }
    return count<=1;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    if(sortedAndRotated(v,n))
    {
        cout<<"True";
    }
    else
    {
        cout<<"False";
    }
}
