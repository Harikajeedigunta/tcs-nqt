#include<iostream>
#include<vector>
#include<climits>
using namespace std;
int smallestSubArrayWithSizeK(vector<int>& v,int n,int k)
{
    int sum=0;
    int min_len=INT_MAX;
    int i=0;
    for(int j=0;j<n;j++)
    {
        sum+=v[j];
        while(sum>=k)
        {
            min_len=min(min_len,j-i+1);
            sum-=v[i];
            i++;
        }
    }
    if(min_len==INT_MAX)
    {
        return 0;
    }
    return min_len;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<smallestSubArrayWithSizeK(v,n,k);
}

