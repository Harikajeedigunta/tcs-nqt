#include<iostream>
#include<vector>
#include<unordered_map>
using namespace std;
int firstRepeatingElement(vector<int>& v,int n)
{
    unordered_map<int,int>mp;
    for(int i=0;i<n;i++)
    {
        mp[v[i]]+=1;
    }
    for(int i=0;i<n;i++)
    {
        if(mp[v[i]]>1)
        {
            return v[i];
        }
    }
    return -1;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<firstRepeatingElement(v,n);
}

