#include<iostream>
#include<vector>
using namespace std;
int search(vector<int>& nums,int k)
{
    int n=nums.size();
    int low=0,high=n-1;
    while(low<=high)
    {
        int mid=(low+high)/2;
        if(nums[mid]==k)
        {
            return mid;
        }
        else if(nums[low]<=nums[mid])
        {
            if(nums[low]<=k && k<=nums[mid])
            {
                high=mid-1;
            }
            else 
            {
                low=mid+1;
            }
        }
        else
        {
            if(nums[mid]<=k && k<=nums[high])
            {
                low=mid+1;
            }
            else
            {
                high=mid-1;
            }
        }
    }
    return -1;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>nums(n);
    for(int i=0;i<n;i++)
    {
        cin>>nums[i];
    }
    cout<<search(nums,k);
}

