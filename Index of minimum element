#include<iostream>
#include<climits>
#include<vector>
using namespace std;
int indexOfMinElement(vector<int>& v,int n)
{
    int min_ele=INT_MAX;
    int min_index=-1;
    for(int i=0;i<n;i++)
    {
        if(v[i]<min_ele)
        {
            min_ele=v[i];
            min_index=i;
        }
    }
    return min_index;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<indexOfMinElement(v,n);
}

