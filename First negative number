#include<iostream>
#include<vector>
using namespace std;
int negativeNum(vector<int>& v,int n)
{
    for(int i=0;i<n;i++)
    {
        if(v[i]<0)
        {
            return v[i];
        }
    }
    return -1;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<negativeNum(v,n);
}

