#include<iostream>
#include<climits>
#include<vector>
using namespace std;
int indexOfMaxElement(vector<int>& v,int n)
{
    int max_element=INT_MIN;
    int max_index=-1;
    for(int i=0;i<n;i++)
    {
        if(v[i]>max_element)
        {
            max_element=v[i];
            max_index=i;
        }
    }
    return max_index;
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<indexOfMaxElement(v,n);
}

