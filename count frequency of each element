Method 1:Using hash map
#include<iostream>
#include<vector>
#include<unordered_map>
using namespace std;
void countFrequency(vector<int>& nums,int n)
{
    unordered_map<int,int>mp;
    for(auto x:nums)
    {
        mp[x]+=1;
    }
    for(const pair<int,int>& p:mp)
    {
        cout<<p.first<<"->"<<p.second<<endl;
    }
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    countFrequency(v,n);
}

Method 2:Using Hashmap
#include<iostream>
#include<vector>
using namespace std;
void countFrequency(vector<int>& nums,int n)
{
    int freq[101]={0};
    for(int x:nums)
    {
        freq[x]++;
    }
    for(int i=0;i<=100;i++)
    {
        if(freq[i]>0)
        {
            cout<<i<<"->"<<freq[i]<<endl;
        }
    }
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    countFrequency(v,n);
}

