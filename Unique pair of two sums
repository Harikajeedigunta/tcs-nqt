#include<iostream>
#include<vector>
using namespace std;
vector<vector<int>> uniquePairsOfTwoSum(vector<int>& v,int n,int k)
{
    int left=0,right=n-1;
    vector<vector<int>>ans;
    while(left<right)
    {
        int sum=v[left]+v[right];
        if(sum==k)
        {
            ans.push_back({v[left],v[right]});
            while(left<right && v[left]==v[left+1]) left++;
            while(left<right && v[right]==v[right-1]) right--;
            left++;
            right--;
        }
        else if(sum<k)
        {
            left++;
        }
        else
        {
            right--;
        }
    }
    return ans;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    vector<vector<int>>result=uniquePairsOfTwoSum(v,n,k);
    for(auto x:result)
    {
        for(auto y:x)
        {
            cout<<y<<" ";
        }
        cout<<endl;
    }
}

