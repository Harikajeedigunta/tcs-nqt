#include<iostream>
#include<vector>
using namespace std;
int firstOccurenceOfK(vector<int>& nums,int n,int k)
{
   int low=0,high=n-1;
   int result=-1;
   while(low<=high)
   {
       int mid=low+(high-low)/2;
       if(nums[mid]==k)
       {
           result=mid;
           high=mid-1;
       }
       else if(nums[mid]<k)
       {
           low=mid+1;
       }
       else
       {
           high=mid-1;
       }
   }
   return result;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<firstOccurenceOfK(v,n,k);
}

