#include<iostream>
#include<vector>
#include<queue>
#include<climits>
using namespace std;
void reArrangeArray(vector<int>&v,int n)
{
    int left=0;
    int right=n-1;
    vector<int>ans;
    while(left<=right)
    {
        if(left!=right)
        {
            ans.push_back(v[right]);
            ans.push_back(v[left]);
        }
        else
        {
            ans.push_back(v[left]);
        }
        left++;
        right--;
    }
    for(int x:ans)
    {
        cout<<x<<" ";
    }
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    reArrangeArray(v,n);
}

