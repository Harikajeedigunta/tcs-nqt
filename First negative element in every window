#include<iostream>
#include<vector>
#include<queue>
using namespace std;
void firstNegativeNumInEverywindow(vector<int>& v,int n,int k)
{
    queue<int>q;
    for(int i=0;i<n;i++)
    {
        if(!q.empty() && q.front()<=i-k)
        {
            q.pop();
        }
        if(v[i]<0)
        {
            q.push(i);
        }
        if(i>=k-1)
        {
            if(!q.empty())
            {
                cout<<v[q.front()]<<" ";
            }
            else
            {
                cout<<"0"<<" ";
            }
        }
    }
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    firstNegativeNumInEverywindow(v,n,k);
}
