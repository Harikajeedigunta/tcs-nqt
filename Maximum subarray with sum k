#include<iostream>
#include<climits>
#include<vector>
using namespace std;
int maxSumSubArray(vector<int>& v,int n,int k)
{
    if(n==0) return 0;
    if(k<=0) return 0;
    if(k>n) return 0;
    int window_sum=0;
    int max_sum=INT_MIN;
    for(int i=0;i<k;i++)
    {
        window_sum+=v[i];
    }
    if(window_sum>max_sum) max_sum=window_sum;
    for(int i=k;i<n;i++)
    {
        window_sum+=v[i]-v[i-k];
        if(window_sum>max_sum)
        {
            max_sum=window_sum;
        }
    }
    return max_sum;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<maxSumSubArray(v,n,k);
}

