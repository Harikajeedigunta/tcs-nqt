#include<iostream>
#include<unordered_map>
#include<vector>
using namespace std;
bool sameFrequency(vector<int>&a,vector<int>& b)
{
    if(a.size()!=b.size()) return false;
    unordered_map<int,int>mp;
    for(int x:a)
    {
        mp[x]+=1;
    }
    for(int x:b)
    {
        mp[x]-=1;
        if(mp[x]<0)
        {
            return false;
        }
    }
    return true;
}
int main()
{
    int m,n;
    cin>>m>>n;
    vector<int> nums1(m),nums2(n);
    for(int i=0;i<m;i++)
    {
        cin>>nums1[i];
    }
    for(int i=0;i<n;i++)
    {
        cin>>nums2[i];
    }
    if(sameFrequency(nums1,nums2))
    {
        cout<<"True"<<endl;
    }
    else
    {
        cout<<"False"<<endl;
    }
}
Input:
4 4
1 2 2 3
2 1 3 2

Output:
True
