#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;
vector<vector<int>> threeSum(vector<int>& v,int n,int k)
{
    sort(v.begin(),v.end());
    vector<vector<int>>ans;
    for(int i=0;i<n-2;i++)
    {
        if(i>0 && v[i]==v[i-1]) continue;
        int first=i+1;
        int last=n-1;
        while(first<last)
        {
            int sum=v[i]+v[first]+v[last];
            if(sum==k)
            {
                ans.push_back({v[i],v[first],v[last]});
                while(first<last && v[first]==v[first+1]) first++;
                while(first<last && v[last]==v[last-1]) last--;

                first++;
                last--;
            }
            else if(sum<k) first++;
            else last--;
        }
    }
    return ans;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    vector<vector<int>>result=threeSum(v,n,k);
    for(auto x:result)
    {
        for(auto y:x)
        {
            cout<<y<<" ";
        }
        cout<<endl;
    }
}

