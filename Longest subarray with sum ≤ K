#include<iostream>
#include<vector>
using namespace std;
int maxLengthSubArray(vector<int>& v,int n,int k)
{
    int max_len=0;
    long long sum=0;
    int i=0;
    for(int j=0;j<n;j++)
    {
        sum+=v[j];
        while(sum>k)
        {
            sum-=v[i];
            i++;
        }
        max_len=max(max_len,j-i+1);
    }
    return max_len;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<maxLengthSubArray(v,n,k);
}

