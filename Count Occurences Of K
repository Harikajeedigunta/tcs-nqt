#include<iostream>
#include<vector>
using namespace std;
int countOccurencesOfK(vector<int>& v,int n,int k)
{
    if(n<=0) return 0;
    int count=0;
    for(int i=0;i<n;i++)
    {
        if(v[i]==k) count+=1;
    }
    return count;
}
int main()
{
    int n,k;
    cin>>n>>k;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    cout<<countOccurencesOfK(v,n,k);
}

