#include<iostream>
#include<algorithm>
#include<vector>
using namespace std;
void waveArray(vector<int>& v,int n)
{
    for(int i=0;i<n-1;i+=2)
    {
        if(v[i]<v[i+1])
        {
            swap(v[i],v[i+1]);
        }
    }
    for(int i=0;i<n;i++)
    {
        cout<<v[i]<<" ";
    }
}
int main()
{
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0;i<n;i++)
    {
        cin>>v[i];
    }
    waveArray(v,n);
}

